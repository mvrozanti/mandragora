+func (nav *nav) autoCalcDirSizes(d *dir) {
+	if d == nil {
+		return
+	}
+	for _, f := range d.allFiles {
+		if !f.IsDir() {
+			continue
+		}
+		path := f.path
+		mtime := f.ModTime()
+
+		nav.dirSizeCacheMu.Lock()
+		entry, ok := nav.dirSizeCache[path]
+		nav.dirSizeCacheMu.Unlock()
+		if ok && entry.mtime.Equal(mtime) {
+			f.dirSize = entry.size
+			continue
+		}
+
+		go func(f *file, path string, mtime time.Time) {
+			nav.dirSizeSem <- struct{}{}
+			defer func() { <-nav.dirSizeSem }()
+
+			total, err := copySize([]string{path})
+			if err != nil {
+				return
+			}
+			f.dirSize = total
+
+			nav.dirSizeCacheMu.Lock()
+			nav.dirSizeCache[path] = dirSizeEntry{size: total, mtime: mtime}
+			nav.dirSizeCacheMu.Unlock()
+
+			select {
+			case nav.dirSizeChan <- struct{}{}:
+			default:
+			}
+		}(f, path, mtime)
+	}
+}
