defaults
auth	on
tls	on
tls_trust_file	/etc/ssl/certs/ca-certificates.crt
logfile	~/.config/msmtp/msmtp.log

account hotmail
host smtp-mail.outlook.com
port 587
from mvrozanti@hotmail.com
user mvrozanti@hotmail.com
passwordeval "pass mutt-wizard-hotmail"


account mvrozanti@hotmail.com
host smtp.office365.com
port 587
from mvrozanti@hotmail.com
user mvrozanti@hotmail.com
passwordeval "/usr/share/neomutt/oauth2/mutt_oauth2.py --encryption-pipe 'gpg -qe -r mvrozanti@hotmail.com' --provider microsoft --client-id 9e5f94bc-e8a4-4e73-b8be-63364c29d753 --client-secret '' --format token /home/m/.cache/mutt/mvrozanti@hotmail.com.tokens"
auth xoauth2
tls on
tls_trust_file	/etc/ssl/certs/ca-certificates.crt
logfile /home/m/.local/state/msmtp/msmtp.log
tls_starttls on
