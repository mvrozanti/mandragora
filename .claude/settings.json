{
  "permissions": {
    "deny": [
      "Bash(python -m venv *)",
      "Bash(python3 -m venv *)",
      "Bash(python3.* -m venv *)",
      "Bash(virtualenv *)",
      "Bash(pip install *)",
      "Bash(pip3 install *)",
      "Bash(python -m pip install *)",
      "Bash(python3 -m pip install *)",
      "Bash(python -m ensurepip *)",
      "Bash(python3 -m ensurepip *)",
      "Bash(poetry install *)",
      "Bash(pipx install *)",
      "Bash(conda install *)"
    ],
    "defaultMode": "auto"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "claude-tmux-sync claude-start",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "claude-tmux-sync claude-end",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash -c 'cols=$(stty size </dev/tty 2>/dev/null | awk '\"'\"'{print $2}'\"'\"'); export COLUMNS=$(( ${cols:-120} > 4 ? ${cols:-120} - 4 : 1 )); plugin_dir=$(ls -d \"${CLAUDE_CONFIG_DIR:-$HOME/.claude}\"/plugins/cache/*/claude-hud/*/ 2>/dev/null | sort -V | tail -1); exec \"/run/current-system/sw/bin/node\" \"${plugin_dir}dist/index.js\"'"
  },
  "effortLevel": "high",
  "skipAutoPermissionPrompt": true,
  "tui": "fullscreen"
}
