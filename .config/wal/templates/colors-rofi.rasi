* {
  black:      {color0};
  red:        {color1};
  green:      {color2};
  yellow:     {color3};
  blue:       {color4};
  magenta:    {color5};
  cyan:       {color6};
  emphasis:   {color8};
  text:       {foreground};
  text-alt:   {color7};
  fg:         {foreground};
  bg:         {background};
}
