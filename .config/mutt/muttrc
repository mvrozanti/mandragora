# NeoMutt Main Configuration
# Catppuccin Rice Edition

# --- General Settings ---
set realname = "Marcelo Vironda Rozanti"
set from     = "mvrozanti@hotmail.com"
set editor   = "nvim"
set date_format = "%y-%m-%d %H:%M"
set index_format = "%Z %D %-20.20n %s"
set sort      = threads
set sort_aux  = reverse-last-date-received
set pager_stop = yes
set sleep_time = 0
set wait_key   = no
set fast_reply = yes
set include    = yes
set reverse_name = yes
set markers    = no
set mail_check = 60
set timeout    = 3
set pipe_decode = yes
set rfc2047_parameters = yes

# --- Sidebar Settings ---
set sidebar_visible = yes
set sidebar_width = 25
set sidebar_short_path = yes
set sidebar_next_new_wrap = yes
set sidebar_format = '%B%* %?N?%N/?%S'
set sidebar_divider_char = '│'

# --- Mailcap / HTML View ---
set mailcap_path = ~/.config/mutt/mailcap
auto_view text/html
alternative_order text/plain text/html

# --- Keybindings (Vim-style) ---
# Unbind 'g' prefix to allow 'gg', 'gi', etc.
bind index,pager g noop

# Navigation (Standard Vim style for NeoMutt)
bind index j next-entry
bind index k previous-entry
bind pager j next-line
bind pager k previous-line

bind index G last-entry
bind pager G bottom
bind index gg first-entry
bind pager gg top
bind index,pager \Cd half-down
bind index,pager \Cu half-up
bind index l display-message
bind index,pager h exit
bind index,pager n next-unread
bind index,pager p previous-unread

# Delete + auto-sync: purge thread, expunge/sync mailbox, then push to server
macro index D "<purge-thread><sync-mailbox><shell-escape>mailsync mvrozanti@hotmail.com<enter>" "Purge thread, expunge, and sync to server"

# Sidebar Navigation
bind index,pager \Ck sidebar-prev
bind index,pager \Cj sidebar-next
bind index,pager \Co sidebar-open
bind index,pager \Ct sidebar-toggle-visible

# Utils
# Auto-sync on startup - wait for sync to finish before showing index
macro index,pager S "<shell-escape>mailsync mvrozanti@hotmail.com<enter>" "sync mail"
macro index \Cr "T~U<enter><tag-prefix><clear-flag>N<untag-pattern>.<enter>" "mark all as read"

# Auto-sync on startup
# This macro runs sync when neomutt first starts
macro index \Ca "<shell-escape>mailsync mvrozanti@hotmail.com<enter>"
push "\Ca"

# --- Theme & Account ---
source ~/.config/mutt/catppuccin.muttrc
source ~/.config/mutt/accounts/mvrozanti@hotmail.com.muttrc

# Folder shortcuts
macro index,pager gi "<change-folder>=INBOX<enter>" "go to INBOX"
macro index,pager gs "<change-folder>=Sent<enter>" "go to Sent"
macro index,pager gd "<change-folder>=Drafts<enter>" "go to Drafts"
macro index,pager gt "<change-folder>=Trash<enter>" "go to Trash"
macro index,pager gj "<change-folder>=Junk<enter>" "go to Junk"

# --- UI Enhancements ---
set status_format = " %f %* %m msgs%?n? (%n new)? — %P "
set sidebar_format = " %B%* %?N?%N? "
set sidebar_width = 30
set pager_index_lines = 12
set help = no
