#!/bin/sh
# Best-effort image clear. On Wayland this isn't reliable (lf#1845) — the
# actual clearing is triggered by the `on-select` redraw command in lfrc.
printf '[%s] cleaner args=%s\n' "$(date +%H:%M:%S.%N)" "$*" >> /tmp/lf-cleaner.log
kitty +kitten icat \
  --clear \
  --stdin no \
  --silent \
  --transfer-mode memory \
  </dev/null >/dev/tty 2>>/tmp/lf-cleaner.log
exit 0
