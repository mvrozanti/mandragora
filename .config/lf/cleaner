#!/bin/sh
printf '[%s] cleaner args=%s\n' "$(date +%H:%M:%S.%N)" "$*" >> /tmp/lf-cleaner.log
prev="$1"
next="$6"
if [ -n "$next" ] && [ "$prev" != "$next" ]; then
  rm -f "/tmp/lf-preview-$PPID.drawn"
  if [ -n "$KITTY_WINDOW_ID" ] && command -v kitty >/dev/null 2>&1; then
    kitty +kitten icat --clear --silent --transfer-mode memory </dev/null >/dev/tty 2>/dev/null
  fi
fi
exit 0
