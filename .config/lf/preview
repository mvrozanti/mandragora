#!/bin/sh
# lf previewer. On kitty, images are drawn via the graphics protocol with
# --transfer-mode memory (stdin data piped in, nothing written through lf's
# captured stdout) and we exit 1 so lf doesn't cache the preview. The lfrc
# `on-select` command triggers a redraw after every selection move, which is
# the only reliable way to clear a previous kitty image on Wayland
# (see lf#1845, ueberzugpp#131 — ueberzugpp-wayland is effectively abandoned
# for lf).
printf '[%s] preview file=%s\n' "$(date +%H:%M:%S.%N)" "$1" >> /tmp/lf-cleaner.log

draw() {
  kitty +kitten icat \
    --stdin no \
    --transfer-mode memory \
    --place "${width}x${height}@${x}x${y}" \
    --scale-up \
    --silent \
    "$1" </dev/null >/dev/tty
}

hash() {
  cache="$HOME/.cache/lf/$(stat --printf '%n\0%i\0%F\0%s\0%W\0%Y' -- "$(readlink -f -- "$1")" | sha256sum | cut -d' ' -f1).jpg"
}

file="$1"
width="$2"
height="$3"
x="$4"
y="$5"

# Serialize previews per lf instance: concurrent icat invocations interleave
# escape-sequence writes to /dev/tty, corrupting the screen on fast scroll.
# Each call records its target as the "wanted" preview (last writer wins);
# after acquiring the lock, abort if the user has already moved past us.
preview_lock="/tmp/lf-preview-$PPID.lock"
preview_want="/tmp/lf-preview-$PPID.want"
preview_drawn="/tmp/lf-preview-$PPID.drawn"
printf '%s' "$file" > "$preview_want.$$" && mv "$preview_want.$$" "$preview_want"
if [ "$(cat "$preview_drawn" 2>/dev/null)" = "$file" ]; then
  printf '[%s] preview-already-drawn file=%s\n' "$(date +%H:%M:%S.%N)" "$file" >> /tmp/lf-cleaner.log
  exit 1
fi
exec 9>"$preview_lock"
if ! flock -w 1 9; then
  printf '[%s] preview-busy file=%s\n' "$(date +%H:%M:%S.%N)" "$file" >> /tmp/lf-cleaner.log
  exit 1
fi
if [ "$(cat "$preview_want" 2>/dev/null)" != "$file" ]; then
  printf '[%s] preview-stale file=%s\n' "$(date +%H:%M:%S.%N)" "$file" >> /tmp/lf-cleaner.log
  exit 1
fi
if [ "$(cat "$preview_drawn" 2>/dev/null)" = "$file" ]; then
  exit 1
fi

if [ -d "$file" ]; then
  resolved=$(readlink -f -- "$file")
  cache_dir="/tmp/lf-dirsize-$USER"
  mkdir -p "$cache_dir"
  key=$(printf '%s' "$resolved" | sha1sum | cut -c1-16)
  cf="$cache_dir/$key"
  if [ -s "$cf" ] && [ "$cf" -nt "$resolved" ]; then
    sz=$(cat "$cf")
  else
    sz=$(timeout 8 du -sh -- "$resolved" 2>/dev/null | cut -f1)
    [ -n "$sz" ] && printf '%s' "$sz" > "$cf"
  fi
  printf '\033[1;33msize:\033[0m %s\n\n' "${sz:-?}"
  if command -v tree >/dev/null 2>&1; then
    tree -a -C -L 2 --dirsfirst "$file" 2>/dev/null | head -$((height - 4))
  else
    ls -la --color=always "$file" 2>/dev/null | head -$((height - 4))
  fi
  exit 0
fi

case "$(file -Lb --mime-type -- "$file")" in
  image/*)
    orientation="$(magick identify -format '%[orientation]\n' -- "$file[0]" 2>/dev/null)"
    if [ -n "$orientation" ] \
        && [ "$orientation" != Undefined ] \
        && [ "$orientation" != TopLeft ]; then
      hash "$file"
      if [ ! -f "$cache" ]; then
        mkdir -p "$(dirname -- "$cache")"
        magick -- "$file[0]" -auto-orient "$cache"
      fi
      draw "$cache"
    else
      draw "$file"
    fi
    printf '%s' "$file" > "$preview_drawn.$$" && mv "$preview_drawn.$$" "$preview_drawn"
    exit 1
    ;;
  video/*)
    hash "$file"
    if [ ! -f "$cache" ]; then
      mkdir -p "$(dirname -- "$cache")"
      ffmpegthumbnailer -i "$file" -o "$cache" -s 0 2>/dev/null
    fi
    draw "$cache"
    printf '%s' "$file" > "$preview_drawn.$$" && mv "$preview_drawn.$$" "$preview_drawn"
    exit 1
    ;;
  application/json)
    jq -C . "$file"
    exit 0
    ;;
  text/*)
    fold -s -w "$width" "$file" | head -n "$height"
    exit 0
    ;;
esac

file -Lb -- "$file" | fold -s -w "$width"
exit 0
