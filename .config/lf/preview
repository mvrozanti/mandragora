#!/bin/sh
# Images use kitty's Unicode-placeholder mode: icat writes PUA placeholder
# characters to stdout (captured by lf into the preview pane), kitty renders
# the image over those cells. When lf later draws text into the same cells,
# the placeholders vanish and kitty stops rendering the image automatically.
# No cleaner / APC-delete required.
printf '[%s] preview file=%s\n' "$(date +%H:%M:%S.%N)" "$1" >> /tmp/lf-cleaner.log

draw() {
  kitty +kitten icat \
    --stdin no \
    --transfer-mode file \
    --unicode-placeholder \
    --place "${width}x${height}@${x}x${y}" \
    --scale-up \
    --silent \
    "$1"
}

hash() {
  cache="$HOME/.cache/lf/$(stat --printf '%n\0%i\0%F\0%s\0%W\0%Y' -- "$(readlink -f -- "$1")" | sha256sum | cut -d' ' -f1).jpg"
}

cache() {
  if ! [ -f "$cache" ]; then
    dir="$(dirname -- "$cache")"
    [ -d "$dir" ] || mkdir -p -- "$dir"
    "$@"
  fi
  draw "$cache"
}

file="$1"
width="$2"
height="$3"
x="$4"
y="$5"

if [ -d "$file" ]; then
  if command -v tree >/dev/null 2>&1; then
    tree -a -C -L 2 --dirsfirst "$file" 2>/dev/null | head -$((height - 2))
  else
    ls -la --color=always "$file" 2>/dev/null | head -$((height - 2))
  fi
  exit 0
fi

case "$(file -Lb --mime-type -- "$file")" in
  image/*)
    orientation="$(magick identify -format '%[orientation]\n' -- "$file[0]" 2>/dev/null)"
    if [ -n "$orientation" ] \
        && [ "$orientation" != Undefined ] \
        && [ "$orientation" != TopLeft ]; then
      hash "$file"
      cache magick -- "$file[0]" -auto-orient "$cache"
    else
      draw "$file"
    fi
    exit 0
    ;;
  video/*)
    hash "$file"
    cache ffmpegthumbnailer -i "$file" -o "$cache" -s 0
    exit 0
    ;;
  application/json)
    jq -C . "$file"
    exit 0
    ;;
  text/*)
    fold -s -w "$width" "$file" | head -n "$height"
    exit 0
    ;;
esac

file -Lb -- "$file" | fold -s -w "$width"
exit 0
