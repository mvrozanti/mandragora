#!/bin/sh
# lf previewer. Images/video thumbs are rendered by ueberzugpp (wayland output)
# as an overlay above kitty — independent of kitty's graphics layer, so no
# clear-bug to fight. The cleaner sends a "remove" to the same daemon.
printf '[%s] preview file=%s\n' "$(date +%H:%M:%S.%N)" "$1" >> /tmp/lf-cleaner.log

file="$1"
width="$2"
height="$3"
x="$4"
y="$5"

show_image() {
  [ -n "${UEBERZUG_SOCKET:-}" ] || return 1
  ueberzugpp cmd \
    -s "$UEBERZUG_SOCKET" \
    -a add \
    -i lf-preview \
    -x "$x" \
    -y "$y" \
    --max-width "$width" \
    --max-height "$height" \
    -f "$1" 2>>/tmp/lf-cleaner.log
}

hash() {
  cache="$HOME/.cache/lf/$(stat --printf '%n\0%i\0%F\0%s\0%W\0%Y' -- "$(readlink -f -- "$1")" | sha256sum | cut -d' ' -f1).jpg"
}

if [ -d "$file" ]; then
  if command -v tree >/dev/null 2>&1; then
    tree -a -C -L 2 --dirsfirst "$file" 2>/dev/null | head -$((height - 2))
  else
    ls -la --color=always "$file" 2>/dev/null | head -$((height - 2))
  fi
  exit 0
fi

case "$(file -Lb --mime-type -- "$file")" in
  image/*)
    orientation="$(magick identify -format '%[orientation]\n' -- "$file[0]" 2>/dev/null)"
    if [ -n "$orientation" ] \
        && [ "$orientation" != Undefined ] \
        && [ "$orientation" != TopLeft ]; then
      hash "$file"
      if [ ! -f "$cache" ]; then
        mkdir -p "$(dirname -- "$cache")"
        magick -- "$file[0]" -auto-orient "$cache"
      fi
      show_image "$cache"
    else
      show_image "$file"
    fi
    exit 1
    ;;
  video/*)
    hash "$file"
    if [ ! -f "$cache" ]; then
      mkdir -p "$(dirname -- "$cache")"
      ffmpegthumbnailer -i "$file" -o "$cache" -s 0 2>/dev/null
    fi
    show_image "$cache"
    exit 1
    ;;
  application/json)
    jq -C . "$file"
    exit 0
    ;;
  text/*)
    fold -s -w "$width" "$file" | head -n "$height"
    exit 0
    ;;
esac

file -Lb -- "$file" | fold -s -w "$width"
exit 0
