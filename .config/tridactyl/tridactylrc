" ── Unbinds ──────────────────────────────────────────────────────────────────
unbind <F1>
unbind ;c
unbind <C-x>
unbind <C-a>
unbind --mode=ex <C-a>
unbind --mode=ex <C-c>
unbind gt

" ── Settings ─────────────────────────────────────────────────────────────────
set modeindicator false
set smoothscroll true
set hintchars asdertgbvcxzq
set hintfiltermode vimperator-reflow
set hintdelay 100

" ── Theme ────────────────────────────────────────────────────────────────────
colors unugly

" ── Navigation & Find ────────────────────────────────────────────────────────
bind / fillcmdline find
bind ? fillcmdline find -?
bind n findnext 1
bind N findnext --reverse 1
bind H back
bind L forward

" ── Tabs ─────────────────────────────────────────────────────────────────────
bind J tabnext
bind K tabprev
bind t tabnew
bind x tabclose
bind D tabduplicate

" ── Open / URL ───────────────────────────────────────────────────────────────
bind o fillcmdline open
bind O fillcmdline tabopen
bind <A-d> composite js window.location.href | fillcmdline open

" ── Scroll ───────────────────────────────────────────────────────────────────
bind b scrollpage -0.5
bind d scrollpage 0.5

" ── Hinting ──────────────────────────────────────────────────────────────────
bind f hint
bind ec hint -A

" ── Yank / Paste ─────────────────────────────────────────────────────────────
bind y composite js document.URL | yank
bind p clipboard open
bind P clipboard tabopen

" ── Misc ─────────────────────────────────────────────────────────────────────
bind <C-V> viewsource
bind i js (() => { const key = "__tri_grayscale"; const current = document.documentElement.getAttribute(key) === "1"; const val = current ? "0" : "1"; document.documentElement.setAttribute(key, val); let style = document.getElementById("tri-grayscale-toggle"); if (!style) { style = document.createElement("style"); style.id = "tri-grayscale-toggle"; document.head.appendChild(style); } style.textContent = val === "1" ? "html { filter: grayscale(100%) invert(100%); }" : ""; })()

" ── GitHub ───────────────────────────────────────────────────────────────────
autocmd DocLoad github.com js document.querySelector("div.flash")?.remove()
bindurl https://github.com gs js (document.querySelector('.starring-container:not(.on) button[aria-label^="Star" i], .starring-container.on button[aria-label^="Unstar" i]') || document.querySelector('button[data-testid="star-button"], button[aria-label^="Star" i], button[aria-label^="Unstar" i]'))?.click()

" ── YouTube ──────────────────────────────────────────────────────────────────
unbindurl https://www.youtube.com /
unbindurl https://www.youtube.com m

autocmd DocStart www.youtube.com js window.__t = window.__t || (function(){const v=e=>e&&!e.hasAttribute("hidden")&&(e.offsetWidth||e.offsetHeight||e.getClientRects().length)&&getComputedStyle(e).display!=="none"&&getComputedStyle(e).visibility!=="hidden"&&parseFloat(getComputedStyle(e).opacity||"1")>0;const ready=(fn,cb)=>{let n=0;const i=setInterval(()=>{let el;try{el=fn()}catch(e){el=null}if(el||++n>20){clearInterval(i);if(el)cb(el)}},100);};return{v,ready,click:sel=>ready(()=>[...document.querySelectorAll(sel)].find(v),el=>el.click())};})()

bindurl https://www.youtube.com gl js window.__t.click('button[aria-label*="like" i], ytd-toggle-button-renderer #button-shape button')
bindurl https://www.youtube.com gd js window.__t.click('button[aria-label*="dislike" i]')
bindurl https://www.youtube.com gc js window.__t.click('ytd-comment-simplebox-renderer #placeholder-area, #contenteditable-root')
bindurl https://www.youtube.com gf js window.__t.click('.ytp-fullscreen-button')
bindurl https://www.youtube.com gs js window.__t.click('button[aria-label^="Subscribe"], ytd-subscribe-button-renderer button')
bindurl https://www.youtube.com gm js window.__t.ready(()=>[...document.querySelectorAll("tp-yt-paper-button#expand, tp-yt-paper-button#collapse")].find(window.__t.v)||[...document.querySelectorAll("tp-yt-paper-button, tp-yt-paper-button button")].find(e=>/more|show less|expand|collapse|mais|mostrar|ver mais/i.test((e.textContent||"").trim())&&window.__t.v(e)), el=>el.click())
bindurl https://www.youtube.com gk js window.__t.ready(()=>[...document.querySelectorAll("button.ytp-play-button, button[aria-keyshortcuts=k], button[aria-label*='Play'], button[aria-label*='Pause']")].find(window.__t.v)||document.querySelector("video"), el=>el.tagName==="VIDEO"?(el.paused?el.play():el.pause()):el.click())
bindurl https://www.youtube.com ? focusinput
bindurl https://www.youtube.com A focusinput
bindurl https://www.youtube.com , focusinput
bindurl https://www.youtube.com f hint -Jc a#thumbnail.yt-simple-endpoint,ytd-comment-thread-renderer a,ytd-channel-name a,paper-button,a#logo,a,.yt-simple-endpoint.style-scope.ytd-toggle-button-renderer#menu-container
bindurl https://www.youtube.com gt js window.__t.ready(()=>[...document.querySelectorAll("button.ytp-size-button, button[title*='Theater'], button[title*='teatro'], button[aria-label*='Theater'], button[aria-label*='teatro']")].find(window.__t.v), el=>el.click())
bindurl https://www.youtube.com gn js window.__t.click('ytd-notification-topbar-button-renderer button')

