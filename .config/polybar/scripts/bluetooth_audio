#!/usr/bin/env bash
CACHE_FILE="/tmp/polybar_bt_status"
DEVICE="04:57:91:D1:38:20"
SINK_BT="bluez_output.04_57_91_D1_38_20.1"
SINK_HDMI="alsa_output.pci-0000_01_00.1.hdmi-stereo"

# Read 2-line cache file: line1=connected, line2=battery (instant, no subprocesses)
if [[ -f "$CACHE_FILE" ]]; then
    { read -r CONNECTED; read -r BAT; } < "$CACHE_FILE"
else
    CONNECTED=0
    BAT=""
fi

if [ "$CONNECTED" -eq 1 ]; then
    ICON="%{F#2196f3}%{F-}"
    CURRENT_SINK=$(pactl info 2>/dev/null | grep "Default Sink" | awk '{print $3}' || echo "")
    if [ "$CURRENT_SINK" = "$SINK_BT" ]; then
        CMD="bluetoothctl disconnect $DEVICE && pactl set-default-sink $SINK_HDMI"
    else
        CMD="bluetoothctl connect $DEVICE; sleep 3; pactl set-default-sink $SINK_BT"
    fi
else
    ICON=""
    CMD="bluetoothctl connect $DEVICE; sleep 3; pactl set-default-sink $SINK_BT"
fi

if [ -n "$BAT" ]; then
    TEXT="$ICON $BAT%"
else
    TEXT="$ICON"
fi

CMD_B64=$(printf '%s' "$CMD" | base64 -w0)
ACTION="sh -c \"echo -n '$CMD_B64' | base64 -d | bash\""
printf "%%{A1:%s:}%s%%{A}\n" "$ACTION" "$TEXT"
